{
  "name": "nodescape",
  "version": "0.1.0",
  "type": "module",
  "description": "React diagramming library for engineering schematics, flow charts, and system visualizations from declarative JSON",
  "author": "Micky Dollimore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dollimore/nodescape"
  },
  "keywords": [
    "react",
    "diagram",
    "flowchart",
    "electrical",
    "schematic",
    "hvdc",
    "nuclear",
    "data-center",
    "hydrogen",
    "scada",
    "dagre",
    "svg"
  ],
  "main": "dist/nodescape.cjs",
  "module": "dist/nodescape.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/nodescape.js",
      "require": "./dist/nodescape.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/nodescape.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": ">=0.300.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "dependencies": {
    "dagre": "^0.8.5"
  },
  "optionalDependencies": {
    "d3-force": "^3.0.0",
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^0.577.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
